# Copy to .env and adjust. Used by django-dotenv in ekho_backend/settings.py.

# Required for any shared or public deployment (generate a new secret per machine):
# SECRET_KEY=

# Local authoring default; set false for exhibit / prep packages:
# DJANGO_DEBUG=false

# Comma-separated hostnames and IPs the server answers to (no spaces):
# ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.10

# Browser origins allowed to send credentialed requests (comma-separated):
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://192.168.1.10:3000

# Origins trusted for CSRF when using session auth from a browser (comma-separated):
# CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://192.168.1.10:3000

# Optional: deployment settings module (PowerShell: $env:DJANGO_SETTINGS_MODULE="ekho_backend.settings_deployment")
# DJANGO_SETTINGS_MODULE=ekho_backend.settings_deployment

# Railway / Postgres: required when using ekho_backend.settings_deployment (no SQLite there).
# Paste DATABASE_URL from the Postgres service (or use a variable reference).
# DATABASE_URL=postgresql://...
#
# Alternative: reference individual libpq vars (no DATABASE_URL). Password is PGPASSWORD or POSTGRES_PASSWORD.
# PGHOST=
# PGPORT=5432
# PGUSER=
# PGPASSWORD=
# PGDATABASE=
# Optional: PGSSLMODE=require

# When terminating TLS in reverse proxy only:
# CSRF_COOKIE_SECURE=true
# SECURE_SSL_REDIRECT=true

# Split hosts (browser on frontend URL, API on another): session cookies need SameSite=None; Secure.
# Requires non-empty CORS_ALLOWED_ORIGINS and CSRF_TRUSTED_ORIGINS. See ../docs/deployment/railway-environment-variables.md
# EKHO_CROSS_SITE_SESSION=1
